# N2-2 Realtime broadcast RLS smoke — 환경 변수 템플릿 (비밀 값 절대 커밋 금지)
# 사용 스크립트: scripts/realtime-smoke/n2-2-broadcast-rls.mjs
#
# 로컬 Supabase 값은 `supabase status` 또는 .env 로 확인. service_role 키는 런타임에만 주입.

# 로컬 API URL (기본: http://127.0.0.1:54321)
SUPABASE_URL=http://127.0.0.1:54321

# publishable/anon 키
SUPABASE_ANON_KEY=

# service_role/secret 키 (admin 작업 전용 — 절대 커밋 금지, 런타임에만 주입)
SUPABASE_SERVICE_ROLE_KEY=

# 로컬 postgres 컨테이너명 — 테스트 사용자 시드용 (본 앱은 OAuth 전용이라 admin API email
# 사용자가 provider CHECK 를 통과하지 못해 docker exec psql 로 시드). 기본값: supabase_db_sagak
DB_CONTAINER=supabase_db_sagak
