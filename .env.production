# Production Environment Variables
# EAS Build profile: production

# Supabase Configuration (Production)
EXPO_PUBLIC_SUPABASE_URL=your-production-project-url.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-production-anon-key

# Sentry DSN (SPEC-DEPLOY-001 M1) — production 빌드 시 validateEnv 가 필수 검증 (REQ-DEPLOY-003)
# 실제 DSN 은 빌드 전에 주입할 것 (이 파일은 placeholder 전용, 실값은 gitignored .env 또는 CI secret).
EXPO_PUBLIC_SENTRY_DSN=

# Environment
ENV=production
