{
  "expo": {
    "name": "sagak",
    "slug": "sagak",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "sagak",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FDFAF5"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sagak.app",
      "infoPlist": {
        "NSUserNotificationsUsageDescription": "읽기 시간 알림과 모임 소식을 받기 위해 알림 권한이 필요합니다."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FDFAF5"
      },
      "package": "com.sagak.app",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "바코드 스캔을 위해 카메라 접근이 필요합니다.",
          "barcodeScannerEnabled": true
        }
      ],
      "expo-secure-store",
      "expo-font",
      "expo-web-browser",
      "expo-notifications",
      [
        "@sentry/react-native",
        {
          "disableAutoUpload": true
        }
      ]
    ]
  }
}
