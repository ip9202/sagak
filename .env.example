# Environment Variables Template
# Copy this file to .env for local development
# REQ-API-016

# Supabase Configuration
EXPO_PUBLIC_SUPABASE_URL=your-project-url.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service Role Key (⚠️ SECURITY WARNING)
# NEVER commit actual service_role_key values to git
# This key bypasses RLS and should only be used on server-side
# For client-side apps, use anon_key only
EXPO_PUBLIC_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Environment
ENV=development
