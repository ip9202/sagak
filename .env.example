# Environment Variables Template
# Copy this file to .env for local development
# REQ-API-016

# Supabase Configuration
EXPO_PUBLIC_SUPABASE_URL=your-project-url.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# NOTE: service_role key is server-only (Edge Functions). NEVER use EXPO_PUBLIC_ prefix for it.

# Sentry DSN (SPEC-DEPLOY-001 M1)
# production 빌드에서 크래시 리포팅을 위해 반드시 필요 (validateEnv 가 검증).
# development 에서는 비워두어도 된다 (dev tolerance).
EXPO_PUBLIC_SENTRY_DSN=

# Environment
ENV=development

# ---------------------------------------------------------------------------
# OAuth Provider Secrets (SERVER-SIDE ONLY — DO NOT put these in client .env)
# ---------------------------------------------------------------------------
# Kakao / Naver / Google OAuth client secrets (client_secret, REST API key 등)은
# Supabase Dashboard > Authentication > Providers 에 서버 사이드로 등록한다.
# 절대 이 파일이나 클라이언트 번들에 넣지 말 것 (EXPO_PUBLIC_ 접두사 금지).
#
# 클라이언트는 OAuth redirect callback URI 만 알면 된다:
#   sagak://auth/callback   (src/auth/oauth.ts getOAuthRedirectUri() 참조)
# ---------------------------------------------------------------------------
