# ============================================
# sagak .gitignore (React Native / Expo)
# ============================================
# Base: HEAD 원본 (sagak RN 맞춤)
# Merged: MoAI-ADK 유용 패턴 (TS/Claude local/MoAI per-machine state)
# Updated: 2026-07-20 — moai update 덮어쓰기 손상 복구
# ============================================

# Dependencies
node_modules/
.yarn/

# Expo
.expo/
.expo-shared/
dist/

# Native
ios/
android/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.pem

# Firebase FCM credentials (SPEC-NOTIF-001)
# google-services.json: Android client config (FCM 등록, 공개 식별자) — 보안 일관성 위해 ignore
# google-service-account.json: FCM V1 서버 private key (EAS Push 전송용, 민감) — eas.json submit 참조
google-services.json
google-service-account.json

# Metro
.metro-health-check*

# Debug
npm-debug.*
yarn-debug.*
yarn-error.*

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Environment
.env
.env.local
.env.*.local

# Sentry CLI local config (SPEC-DEPLOY-001 — contains auth token, must never commit)
sentry.properties
.sentryclirc

# Keep staging/production env templates for EAS builds (but not actual values)
!.env.example
!.env.staging
!.env.production

# OS
.DS_Store
Thumbs.db

# Testing
coverage/
*.log

# Temporary
*.tmp
*.temp

# MoAI logs
.moai/logs/
.moai/reports/
*.bak
*.bak[0-9]

# ============================================
# MoAI-ADK 병합 패턴 (2026-07-20 추가)
# sagak(RN)에 해당하는 MoAI 유용 패턴만 선택 — Go/Python 패턴은 제외
# ============================================

# TypeScript / JS 산물
*.tsbuildinfo
.tscache/
.next/
out/

# Claude Code local state (per-machine, never tracked)
.claude/settings.local.json
.claude/settings.local.json.lock
.claude/settings.local.*.json
.claude/plans/
.claude/agent-memory/
.claude/worktrees/
.claude/.env.local*
.claude/local/

# Claude skill credentials
.claude/skills/*/.env*
.claude/skills/*/secrets/

# MoAI per-machine state (never tracked)
.moai/status_line.sh
.moai/memory/
.moai/worktrees/
.moai/branches/
.moai/state/
.moai/cache/
.moai-backups/
.moai/backups/

# Firebase deploy cache (sagak Firebase 사용)
.firebase/
